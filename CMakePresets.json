{
    "version": 6,
    "configurePresets": [
        {
            "name": "dev",
            "displayName": "Development",
            "binaryDir": "${sourceDir}/build/dev",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "DCX_INCLUDE_ALL_SORTERS": "ON",
                "DCX_OPTIMIZE_DATA_TYPES": "OFF",
                "IPS4O_DISABLE_PARALLEL": "ON",
                "KASSERT_ASSERTION_LEVEL": "30"
            }
        },
        {
            "name": "experiments",
            "displayName": "Experiments",
            "binaryDir": "${sourceDir}/build/experiments",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "DCX_INCLUDE_ALL_SORTERS": "ON",
                "DCX_OPTIMIZE_DATA_TYPES": "OFF",
                "IPS4O_DISABLE_PARALLEL": "ON",
                "KASSERT_ASSERTION_LEVEL": "0"
            }
        },
        {
            "name": "github-ci",
            "displayName": "GitHub CI",
            "binaryDir": "${sourceDir}/build/ci",
            "cacheVariables": {
                "DCX_INCLUDE_ALL_SORTERS": "ON",
                "DCX_OPTIMIZE_DATA_TYPES": "OFF",
                "IPS4O_DISABLE_PARALLEL": "ON",
                "DCX_BUILD_EXAMPLES": "ON",
                "DCX_BUILD_TESTS": "ON",
                "KASSERT_ASSERTION_LEVEL": "30"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "dev",
            "configurePreset": "dev"
        },
        {
            "name": "experiments",
            "configurePreset": "experiments"
        },
        {
            "name": "github-ci",
            "configurePreset": "github-ci"
        }
    ],
    "testPresets": [
        {
            "name": "github-ci",
            "configurePreset": "github-ci",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
